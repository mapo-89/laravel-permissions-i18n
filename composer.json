{
    "name": "mapo-89/laravel-permissions-i18n",
    "description": "JSON translations for Spatie Laravel Permission package",
    "keywords": [
        "mapo-89",
        "laravel",
        "laravel-permissions-i18n"
    ],
    "homepage": "https://github.com/mapo-89/laravel-permissions-i18n",
    "license": "MIT",
    "authors": [
        {
            "name": "mapo-89",
            "email": "info@postler.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Mapo89\\LaravelPermissionsI18n\\": "src/",
            "Mapo89\\LaravelPermissionsI18n\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mapo89\\LaravelPermissionsI18n\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mapo89\\LaravelPermissionsI18n\\LaravelPermissionsI18nServiceProvider"
            ],
            "aliases": {
                "LaravelPermissionsI18n": "Mapo89\\LaravelPermissionsI18n\\Facades\\LaravelPermissionsI18n"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
